# Configuración del Bot
BOT_TOKEN=your_bot_token_here
SUPER_ADMIN_CHAT_ID=your_chat_id_here

# No es necesario modificar estas rutas para Docker
DOWNLOAD_DIR=/data/downloads
SAVED_VIDEOS_DIR=/data/saved_videos
DB_PATH=/data/db/users.db

# --- NFS (Opción A: Docker monta NFS directo con driver local) ---
# Usado por: docker-compose.nfs.yml
NFS_SERVER=192.168.X.Y
NFS_EXPORT_DOWNLOADS=/ruta/exportada/mediabot/downloads
NFS_EXPORT_SAVED_VIDEOS=/ruta/exportada/mediabot/saved_videos
# NFS_VERS=4

# --- NFS (Opción B: NFS ya montado en el host; usar bind-mount) ---
# Usado por: docker-compose.nfs.bind.yml
# Ejemplo: NFS_MOUNT_BASE=/mnt/raspi_videos
NFS_MOUNT_BASE=/ruta/del/mount/nfs